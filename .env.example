DRIVER=~websockets
HOST=127.0.0.1
PORT=8080
LOG_LEVEL=INFO

ONEBOT_V11_WS_URLS=["ws://127.0.0.1:6098"]
ONEBOT_V11_ACCESS_TOKEN=replace-with-onebot-token

OPENCLAW_URL=http://127.0.0.1:18789/v1/responses
OPENCLAW_TOKEN=replace-with-openclaw-token
OPENCLAW_MODEL=moonshot/kimi-k2.5
OPENCLAW_AGENT_ID=qq_bot
OPENCLAW_ROUTER_AGENT_ID=qq_router
OPENCLAW_ROUTER_MODEL=moonshot/kimi-k2.5
OPENCLAW_CONFIG_PATH=/root/.openclaw/openclaw.json

QQ_ALLOWED_GROUP_IDS=1081502166,608990365,834689068
QQ_BOT_ACK_EMOJI_ID=128064
QQ_BOT_WORKSPACE=/path/to/game_demo
QQ_BOT_TODOLIST_PATH=/path/to/game_demo/nonebot2/todolist.md
QQ_BOT_DESCRIPTION_PATH=/path/to/game_demo/nonebot2/description.md
QQ_GROUP_OPENCLAW_WORKSPACE_ROOT=/path/to/game_demo/nonebot2/data/openclaw_group_memory

DOTA2_ENABLED=true
DOTA2_STEAM_API_KEY=replace-with-steam-api-key
DOTA2_STEAM_API_BASE=http://api.steampowered.com
DOTA2_NOTIFY_GROUP_ID=1081502166
DOTA2_POLL_INTERVAL_SECONDS=300
DOTA2_HISTORY_WINDOW=1
DOTA2_SEQUENCE_BATCH_SIZE=1
DOTA2_OUTPUT_VERSION=v2
DOTA2_V2_MAX_MATCHES_PER_RUN=1
DOTA2_V2_STARTUP_BACKFILL_MATCHES=0
DOTA2_HERO_CACHE_FILE=/path/to/game_demo/nonebot2/data/dota2_monitor/heroes.json
DOTA2_ITEM_CACHE_FILE=/path/to/game_demo/nonebot2/data/dota2_monitor/items.json
DOTA2_MATCH_DB_PATH=/path/to/game_demo/nonebot2/data/dota2_monitor/matches.sqlite3
DOTA2_V2_DEBUG=false

DOTA2_KNOWLEDGE_ENABLED=true
DOTA2_KNOWLEDGE_SYNC_INTERVAL_SECONDS=21600
DOTA2_KNOWLEDGE_DATA_DIR=/path/to/game_demo/nonebot2/data/dota_knowledge
DOTA2_KNOWLEDGE_MATCHUP_MIN_GAMES=200
DOTA2_KNOWLEDGE_USE_TAVILY_FOR_PATCH=true

TAVILY_API_KEY=replace-with-tavily-api-key
TAVILY_API_URL=https://api.tavily.com/search
TAVILY_MAX_RESULTS=5

QQ_IDLE_JOKE_GROUP_IDS=1081502166
QQ_IDLE_JOKE_VERSION=v2
QQ_IDLE_JOKE_V2_API_URL=https://tools.mgtv100.com/external/v1/pear/duanZi
QQ_IDLE_JOKE_V2_TIMEOUT_SECONDS=10
QQ_IDLE_JOKE_V2_MAX_RETRIES=10
QQ_IDLE_JOKE_DB_PATH=/path/to/game_demo/nonebot2/data/idle_joke/jokes.sqlite3

QQ_GROUP_CHAT_REDIS_URL=redis://127.0.0.1:6379/0
QQ_GROUP_CHAT_REDIS_KEY_PREFIX=nonebot2:group_chat
QQ_GROUP_MEMORY_INTERVAL_SECONDS=7200
QQ_GROUP_MEMORY_MAX_CONTEXT_ITEMS=100
QQ_GROUP_MEMORY_DB_PATH=/path/to/game_demo/nonebot2/data/group_memory/group_memory.sqlite3
